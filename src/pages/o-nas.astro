---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import data from '../data/o-nas.json';
---

<Layout title="O nás" description="Jsme specialisté na tepelná čerpadla a úsporné vytápění. Pracujeme od roku 2008, máme za sebou stovky instalací po celé ČR.">
  <PageHero
    title={data.hero_title}
    subtitle={data.hero_subtitle}
    breadcrumb={[{ label: 'O nás', href: '/o-nas' }]}
  />

  <section class="pt-10 pb-16 lg:pt-12 lg:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <div class="text-brand-500 text-sm font-semibold uppercase tracking-wider mb-3">{data.philosophy_label}</div>
          <h2 class="text-3xl font-extrabold text-charcoal-900 mb-6" set:html={data.philosophy_headline}></h2>
          <div class="space-y-4 text-charcoal-600 leading-relaxed">
            <p>{data.philosophy_text1}</p>
            <p>{data.philosophy_text2}</p>
            <p>{data.philosophy_text3}</p>
          </div>
        </div>

        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            {[
              { num: data.stat1_num, label: data.stat1_label },
              { num: data.stat2_num, label: data.stat2_label },
              { num: data.stat3_num, label: data.stat3_label },
              { num: data.stat4_num, label: data.stat4_label },
            ].map(item => (
              <div class="bg-gray-50 rounded-xl p-6 border border-gray-200 text-center">
                <div class="text-3xl font-extrabold text-navy-700 mb-1">{item.num}</div>
                <div class="text-xs text-charcoal-500">{item.label}</div>
              </div>
            ))}
          </div>

          <div class="bg-navy-700 rounded-xl p-6 text-white">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-brand-500 rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-sm">JS</div>
              <div>
                <blockquote class="text-sm text-navy-200 leading-relaxed italic mb-3">
                  "{data.testimonial_quote}"
                </blockquote>
                <div class="text-sm font-semibold text-white">{data.testimonial_name}</div>
                <div class="text-xs text-navy-300">{data.testimonial_company}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-10 text-center">{data.process_headline}</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {[
          { num: data.step1_num, title: data.step1_title, desc: data.step1_desc },
          { num: data.step2_num, title: data.step2_title, desc: data.step2_desc },
          { num: data.step3_num, title: data.step3_title, desc: data.step3_desc },
          { num: data.step4_num, title: data.step4_title, desc: data.step4_desc },
        ].map(item => (
          <div class="bg-white rounded-xl p-7 border border-gray-200">
            <div class="text-4xl font-extrabold text-brand-100 mb-4">{item.num}</div>
            <h3 class="font-bold text-charcoal-900 mb-2">{item.title}</h3>
            <p class="text-sm text-charcoal-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-4">{data.cta_headline}</h2>
      <p class="text-charcoal-500 mb-8">{data.cta_text}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">{data.cta_button}</a>
        <a href="tel:+420777724573" class="inline-flex items-center justify-center px-6 py-3.5 border-2 border-gray-200 hover:border-gray-400 text-charcoal-700 font-semibold rounded-md transition-colors">+420 777 724 573</a>
      </div>
    </div>
  </section>
</Layout>
