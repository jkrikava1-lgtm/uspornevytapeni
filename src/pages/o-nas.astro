---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="O nás" description="Jsme specialisté na tepelná čerpadla a úsporné vytápění. Pracujeme od roku 2008, máme za sebou stovky instalací po celé ČR.">
  <PageHero
    title="O nás"
    subtitle="Tepelná čerpadla jsou naše parketa od roku 2008. Za tu dobu jsme navrhli a instalovali stovky systémů po celé České republice."
    breadcrumb={[{ label: 'O nás', href: '/o-nas' }]}
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <div class="text-brand-500 text-sm font-semibold uppercase tracking-wider mb-3">Naše filozofie</div>
          <h2 class="text-3xl font-extrabold text-charcoal-900 mb-6">Nejlepší systém vytápění<br>je ten, který prostě funguje</h2>
          <div class="space-y-4 text-charcoal-600 leading-relaxed">
            <p>
              Úsporné vytápění s.r.o. vzniklo s jednoduchým cílem: nabídnout lidem systémy vytápění, které skutečně šetří peníze, nevyžadují obsluhu a vydrží desítky let bez starostí.
            </p>
            <p>
              Specializujeme se výhradně na tepelná čerpadla značky Master Therm — česká výroba s mezinárodním oceněním. Jsme autorizovaným partnerem a servisním centrem, takže za vším stojíme přímo my — bez prostředníků.
            </p>
            <p>
              Pracujeme s domácnostmi i firmami. Každý projekt začíná bezplatnou konzultací a končí funkčním systémem, na který se klient může spolehnout rok co rok.
            </p>
          </div>
        </div>

        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            {[
              { num: '2008', label: 'Rok založení' },
              { num: '500+', label: 'Instalací ročně' },
              { num: '15+', label: 'Let na trhu' },
              { num: '98 %', label: 'Spokojených klientů' },
            ].map(item => (
              <div class="bg-gray-50 rounded-xl p-6 border border-gray-200 text-center">
                <div class="text-3xl font-extrabold text-navy-700 mb-1">{item.num}</div>
                <div class="text-xs text-charcoal-500">{item.label}</div>
              </div>
            ))}
          </div>

          <div class="bg-navy-700 rounded-xl p-6 text-white">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-brand-500 rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-sm">JS</div>
              <div>
                <blockquote class="text-sm text-navy-200 leading-relaxed italic mb-3">
                  "Úsporné vytápění patří mezi naše nejspolehlivější dlouhodobé partnery. Realizují zakázky v hodnotách milionů korun ročně s vynikající kvalitou instalací."
                </blockquote>
                <div class="text-sm font-semibold text-white">Ing. Jiří Svoboda</div>
                <div class="text-xs text-navy-300">Master Therm a.s.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-10 text-center">Jak pracujeme</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {[
          { num: '01', title: 'Konzultace', desc: 'Zavoláte nebo napíšete. Probereme vaši situaci a potřeby — zdarma, bez závazků.' },
          { num: '02', title: 'Návrh řešení', desc: 'Navrhneme optimální systém s odhadovanou úsporou a náklady na provoz.' },
          { num: '03', title: 'Instalace', desc: 'Dohodnutý termín, čistá práce, minimální zásah do vašeho běžného života.' },
          { num: '04', title: 'Podpora', desc: 'Po spuštění jsme stále k dispozici — servis, záruky, pravidelné prohlídky.' },
        ].map(item => (
          <div class="bg-white rounded-xl p-7 border border-gray-200">
            <div class="text-4xl font-extrabold text-brand-100 mb-4">{item.num}</div>
            <h3 class="font-bold text-charcoal-900 mb-2">{item.title}</h3>
            <p class="text-sm text-charcoal-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-4">Chcete vědět víc?</h2>
      <p class="text-charcoal-500 mb-8">Zavolejte nám nebo pošlete poptávku. Rádi odpovíme na vaše otázky.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">Odeslat poptávku</a>
        <a href="tel:+420777724573" class="inline-flex items-center justify-center px-6 py-3.5 border-2 border-gray-200 hover:border-gray-400 text-charcoal-700 font-semibold rounded-md transition-colors">+420 777 724 573</a>
      </div>
    </div>
  </section>
</Layout>
