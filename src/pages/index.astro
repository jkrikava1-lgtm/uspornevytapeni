---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tepelná čerpadla a úsporné vytápění" description="Navrhujeme a instalujeme tepelná čerpadla a systémy úsporného vytápění na míru. Novostavby i rekonstrukce. Bezplatná konzultace.">

  <!-- HERO -->
  <section class="relative bg-navy-700 text-white overflow-hidden pt-16 lg:pt-20">
    <div class="absolute inset-0 opacity-5">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>
    <!-- Red accent bar na levé straně -->
    <div class="absolute left-0 top-0 bottom-0 w-1 bg-brand-500"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-navy-600 text-navy-200 text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
          <span class="w-1.5 h-1.5 bg-brand-500 rounded-full"></span>
          Tepelná čerpadla Master Therm — česká výroba od 1998
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Vytápějte chytře.<br>
          <span class="text-brand-400">Ušetřete až 70 %</span><br>
          nákladů na energie.
        </h1>
        <p class="text-lg text-navy-200 mb-10 max-w-xl leading-relaxed">
          Navrhujeme a instalujeme tepelná čerpadla a systémy úsporného vytápění od roku 2008. Bezobslužný provoz, online ovládání, záruka kvality.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors text-base">
            Chci bezplatnou konzultaci
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href="/reference" class="inline-flex items-center justify-center px-6 py-3.5 border border-navy-500 hover:border-navy-300 text-navy-200 hover:text-white font-semibold rounded-md transition-colors text-base">
            Prohlédnout reference
          </a>
        </div>

        <!-- Trust bar -->
        <div class="mt-12 pt-10 border-t border-navy-600 grid grid-cols-3 gap-6 max-w-lg">
          <div>
            <div class="text-2xl font-extrabold text-white">500+</div>
            <div class="text-xs text-navy-300 mt-0.5">instalací ročně</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold text-white">15+</div>
            <div class="text-xs text-navy-300 mt-0.5">let zkušeností</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold text-white">98 %</div>
            <div class="text-xs text-navy-300 mt-0.5">spokojených klientů</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA CARDS -->
  <section class="bg-gray-50 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl lg:text-3xl font-bold text-charcoal-900 mb-3">Jak vám můžeme pomoci?</h2>
        <p class="text-charcoal-500 max-w-xl mx-auto">Vyberte situaci, která odpovídá vaší potřebě.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <a href="/navrh-reseni/novostavba" class="group bg-white rounded-xl p-8 border border-gray-200 hover:border-brand-300 hover:shadow-lg transition-all duration-200">
          <div class="w-12 h-12 bg-brand-50 group-hover:bg-brand-500 rounded-lg flex items-center justify-center mb-5 transition-colors">
            <svg class="w-6 h-6 text-brand-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-charcoal-900 mb-2">Stavím nový dům</h3>
          <p class="text-sm text-charcoal-500 leading-relaxed mb-4">Navrhneme optimální systém vytápění pro vaši novostavbu — tepelné čerpadlo, podlahové vytápění i chlazení v jednom.</p>
          <span class="text-sm font-semibold text-brand-500 group-hover:text-brand-600 flex items-center gap-1">
            Více informací
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <a href="/navrh-reseni/stavajici-dum" class="group bg-white rounded-xl p-8 border border-gray-200 hover:border-brand-300 hover:shadow-lg transition-all duration-200">
          <div class="w-12 h-12 bg-brand-50 group-hover:bg-brand-500 rounded-lg flex items-center justify-center mb-5 transition-colors">
            <svg class="w-6 h-6 text-brand-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-charcoal-900 mb-2">Rekonstruuji vytápění</h3>
          <p class="text-sm text-charcoal-500 leading-relaxed mb-4">Přecházíte z kotle na plyn nebo tuhá paliva? Vyměníme starý systém za tepelné čerpadlo bez zbytečných komplikací.</p>
          <span class="text-sm font-semibold text-brand-500 group-hover:text-brand-600 flex items-center gap-1">
            Více informací
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <a href="/navrh-reseni/velky-vykon" class="group bg-white rounded-xl p-8 border border-gray-200 hover:border-brand-300 hover:shadow-lg transition-all duration-200">
          <div class="w-12 h-12 bg-brand-50 group-hover:bg-brand-500 rounded-lg flex items-center justify-center mb-5 transition-colors">
            <svg class="w-6 h-6 text-brand-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-charcoal-900 mb-2">Potřebuji velký výkon</h3>
          <p class="text-sm text-charcoal-500 leading-relaxed mb-4">Pro bytové domy, komerční objekty i průmysl. Navrhujeme kaskádové systémy s výkonem od 20 do 200 kW.</p>
          <span class="text-sm font-semibold text-brand-500 group-hover:text-brand-600 flex items-center gap-1">
            Více informací
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

      </div>
    </div>
  </section>

  <!-- PROČ TEPELNÁ ČERPADLA -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="text-brand-500 text-sm font-semibold uppercase tracking-wider mb-3">Proč tepelné čerpadlo</div>
          <h2 class="text-3xl lg:text-4xl font-extrabold text-charcoal-900 mb-6">Nejúspornější způsob<br>vytápění dnes dostupný</h2>
          <p class="text-charcoal-500 mb-8 leading-relaxed">
            Tepelné čerpadlo vytváří ze 1 kWh elektrické energie 3–5 kWh tepla. Oproti plynovému kotli ušetříte průměrně 60–70 % ročních nákladů na vytápění.
          </p>
          <div class="space-y-5">
            {[
              { title: 'Úspora 60–70 % nákladů', desc: 'Průměrná roční úspora oproti plynovému kotli při cenách energií 2024.' },
              { title: '100% bezobslužný provoz', desc: 'Žádné přikládání, žádná obsluha. Systém funguje sám, vy se jen zahříváte.' },
              { title: 'Topení i chlazení v jednom', desc: 'V létě zařízení obrátí chod a funguje jako klimatizace. Dvě funkce za cenu jedné.' },
              { title: 'Online ovládání odkudkoliv', desc: 'Přes mobilní aplikaci nastavíte teplotu z kanceláře, z dovolené, kdekoliv.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-8 h-8 bg-brand-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-charcoal-900 text-sm mb-0.5">{item.title}</div>
                  <div class="text-sm text-charcoal-500">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Graf úspory -->
        <div class="bg-navy-700 rounded-2xl p-8 lg:p-10 text-white relative overflow-hidden">
          <div class="absolute -right-8 -top-8 w-40 h-40 bg-navy-600 rounded-full opacity-60"></div>
          <div class="absolute -left-4 -bottom-4 w-28 h-28 bg-brand-500 rounded-full opacity-15"></div>
          <div class="relative">
            <div class="text-brand-400 text-sm font-semibold uppercase tracking-wider mb-4">Příklad úspory</div>
            <div class="text-5xl font-extrabold mb-2">68 %</div>
            <div class="text-navy-300 text-sm mb-8">průměrná roční úspora na vytápění</div>
            <div class="space-y-4">
              <div>
                <div class="flex justify-between text-xs text-navy-300 mb-1.5">
                  <span>Plynový kotel</span><span>45 000 Kč / rok</span>
                </div>
                <div class="h-2 bg-navy-600 rounded-full">
                  <div class="h-2 bg-charcoal-400 rounded-full w-full"></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-xs text-navy-300 mb-1.5">
                  <span>Tepelné čerpadlo</span><span>14 400 Kč / rok</span>
                </div>
                <div class="h-2 bg-navy-600 rounded-full">
                  <div class="h-2 bg-brand-500 rounded-full" style="width: 32%"></div>
                </div>
              </div>
            </div>
            <div class="mt-8 pt-6 border-t border-navy-600 text-xs text-navy-400">
              * Příklad pro dům 150 m², průměrné zateplení, ceny energií 2024
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROČ MY -->
  <section class="bg-gray-50 py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <div class="text-brand-500 text-sm font-semibold uppercase tracking-wider mb-3">Proč Úsporné vytápění</div>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-charcoal-900">Solidní práce, žádné kompromisy</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            title: 'Ověřená kvalita',
            desc: 'Dodáváme výhradně certifikované produkty od prověřených výrobců. Žádné experimentování na vašem domě.'
          },
          {
            icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
            title: 'Master Therm',
            desc: 'Autorizovaný partner výrobce Master Therm — česká tepelná čerpadla s mezinárodním oceněním.'
          },
          {
            icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
            title: 'Servis od výrobce',
            desc: 'Servis zajišťujeme přímo — bez prostředníků, bez čekání. Rychlá odezva a náhradní díly skladem.'
          },
          {
            icon: 'M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z',
            title: 'Podpora po celou dobu',
            desc: 'Od prvního hovoru přes instalaci až po servisní prohlídku. Jsme tu pro vás, ne jen při prodeji.'
          },
        ].map(item => (
          <div class="bg-white rounded-xl p-7 border border-gray-200">
            <div class="w-11 h-11 bg-navy-700 rounded-lg flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
              </svg>
            </div>
            <h3 class="font-bold text-charcoal-900 mb-2">{item.title}</h3>
            <p class="text-sm text-charcoal-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <svg class="w-10 h-10 text-brand-400 mx-auto mb-6" fill="currentColor" viewBox="0 0 32 32">
        <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z"/>
      </svg>
      <blockquote class="text-xl lg:text-2xl font-medium text-charcoal-800 leading-relaxed mb-8">
        "Firma Úsporné vytápění nám místo elektrokotle namontovala tepelné čerpadlo vzduch-voda Master Therm. Provoz je jednoduchý, bezproblémový a hlavně o dvě třetiny levnější. S jejich prací jsme velmi spokojeni."
      </blockquote>
      <div class="flex items-center justify-center gap-3">
        <div class="w-10 h-10 bg-brand-100 rounded-full flex items-center justify-center text-brand-600 font-bold text-sm">RV</div>
        <div class="text-left">
          <div class="font-semibold text-charcoal-900 text-sm">Roman Vojtek</div>
          <div class="text-xs text-charcoal-500">Praha — tepelné čerpadlo vzduch-voda</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TYPY TČ -->
  <section class="bg-navy-700 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-brand-400 text-sm font-semibold uppercase tracking-wider mb-3">Naše produkty</div>
        <h2 class="text-3xl font-extrabold text-white">Tepelná čerpadla pro každou situaci</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { href: '/tepelna-cerpadla/vzduch-voda', emoji: '🌬️', title: 'Vzduch – voda', desc: 'Nejrozšířenější typ. Snadná instalace, výborný poměr cena/výkon. Vhodné pro 95 % domácností.' },
          { href: '/tepelna-cerpadla/zeme-voda', emoji: '🌱', title: 'Země – voda', desc: 'Nejvyšší účinnost i v mrazivých zimách. Ideální tam, kde je dost pozemku pro zemní kolektory.' },
          { href: '/tepelna-cerpadla/voda-voda', emoji: '💧', title: 'Voda – voda', desc: 'Maximální výkon a účinnost. Pro objekty s přístupem k podzemní vodě nebo vodnímu zdroji.' },
        ].map(item => (
          <a href={item.href} class="group bg-navy-600 hover:bg-navy-500 rounded-xl p-7 transition-colors">
            <div class="text-4xl mb-4">{item.emoji}</div>
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-navy-200 leading-relaxed mb-4">{item.desc}</p>
            <span class="text-sm font-semibold text-brand-400 group-hover:text-brand-300 flex items-center gap-1">
              Zjistit více
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DOTACE BANNER -->
  <section class="bg-brand-500 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <div class="text-white/70 text-sm font-semibold uppercase tracking-wider mb-1">Nová zelená úsporám</div>
          <h3 class="text-2xl font-extrabold text-white">Získejte dotaci až 200 000 Kč</h3>
          <p class="text-white/80 text-sm mt-1">Pomůžeme vám s celým procesem žádosti — od poradenství po schválení.</p>
        </div>
        <a href="/dotace" class="flex-shrink-0 inline-flex items-center px-6 py-3 bg-white text-brand-600 font-semibold rounded-md hover:bg-brand-50 transition-colors text-sm">
          Zjistit nárok na dotaci
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-charcoal-900 mb-4">Připraveni začít?</h2>
      <p class="text-charcoal-500 mb-8 max-w-xl mx-auto">
        Zavolejte nám nebo vyplňte poptávkový formulář. Konzultace je zdarma, bez závazků.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">
          Odeslat poptávku
        </a>
        <a href="tel:+420800123456" class="inline-flex items-center justify-center px-6 py-3.5 border-2 border-gray-200 hover:border-gray-400 text-charcoal-700 font-semibold rounded-md transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          800 123 456
        </a>
      </div>
    </div>
  </section>

</Layout>
