---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Katalog — Voda-voda" description="Kompletní katalog tepelných čerpadel voda-voda Master Therm. AquaMaster, AquaMaster Inverter, AquaMaster Inverter Combi. Výkony, COP, technické listy.">
  <PageHero
    title="Tepelná čerpadla voda – voda"
    subtitle="Kompletní katalog modelů Master Therm"
    breadcrumb={[{ label: 'Katalog', href: '/katalog' }, { label: 'Voda – voda', href: '/katalog/voda-voda' }]}
  />

  <section class="pt-10 pb-16 lg:pt-12 lg:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex gap-3 mb-8">
        <a href="/katalog/vzduch-voda" class="inline-flex px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-charcoal-500 hover:bg-gray-200 transition-colors">Vzduch-voda</a>
        <a href="/katalog/zeme-voda" class="inline-flex px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-charcoal-500 hover:bg-gray-200 transition-colors">Země-voda</a>
        <span class="inline-flex px-3 py-1 rounded-full text-xs font-semibold bg-cyan-100 text-cyan-700">Voda-voda</span>
      </div>

      <div class="bg-gray-50 rounded-xl p-5 border border-gray-200 mb-12">
        <div class="text-xs text-charcoal-400 font-semibold uppercase tracking-wider mb-3">Produktové řady</div>
        <div class="flex flex-wrap gap-3">
          <a href="#aquamaster" class="text-sm font-semibold text-navy-700 hover:text-brand-500 transition-colors">AquaMaster</a>
          <span class="text-gray-300">|</span>
          <a href="#aquamaster-inverter" class="text-sm font-semibold text-navy-700 hover:text-brand-500 transition-colors">AquaMaster Inverter</a>
          <span class="text-gray-300">|</span>
          <a href="#aquamaster-combi" class="text-sm font-semibold text-navy-700 hover:text-brand-500 transition-colors">AquaMaster Inverter Combi</a>
        </div>
      </div>

      <!-- 1. AquaMaster -->
      <div id="aquamaster" class="scroll-mt-24 mb-16">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-10 bg-navy-700 text-white rounded-full flex items-center justify-center font-bold text-lg flex-shrink-0">1</div>
          <div>
            <h2 class="text-xl font-extrabold text-charcoal-900">AquaMaster</h2>
            <p class="text-charcoal-500 text-sm">Scroll kompresor, 10,4–90,9 kW</p>
          </div>
        </div>

        <div class="mb-6">
          <div class="flex gap-6 mb-4">
            <div class="flex-1">
              <p class="text-charcoal-600 text-sm leading-relaxed">
                Tepelné čerpadlo voda-voda ve výkonu od 8 do 90 kW. Nerezové deskové nebo trubkové výměníky (odolnější proti zanášení vodním kamenem), oběhová čerpadla primárního i topného okruhu v ceně, velmi tichý chod scroll kompresoru. Velmi tiché a výkonné tepelné čerpadlo, velmi efektivní v konfiguraci voda-voda.
              </p>
            </div>
            <img src="/images/products/aquamaster-2z.png" alt="AquaMaster" class="w-36 h-36 object-contain flex-shrink-0 hidden sm:block" />
          </div>
          <div class="space-y-2">
            {[
              'nerezové deskové nebo trubkové výměníky — odolné proti vodnímu kameni',
              'oběhová čerpadla primárního i topného okruhu v ceně',
              'velmi tichý chod scroll kompresoru',
              'optimální poměr ceny a výkonu',
            ].map(item => (
              <div class="flex gap-2 items-start">
                <div class="w-4 h-4 bg-brand-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-charcoal-600 text-sm">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="overflow-x-auto rounded-xl border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-navy-700 text-white">
              <tr>
                <th class="text-left px-5 py-3 font-semibold">Model</th>
                <th class="text-left px-5 py-3 font-semibold">Výkon</th>
                <th class="text-left px-5 py-3 font-semibold">COP</th>
                <th class="px-5 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {[
                { model: 'AquaMaster 22Z', vykon: '10,4 kW', cop: '5,9', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq22z_410a_14511.pdf' },
                { model: 'AquaMaster 26Z', vykon: '13,3 kW', cop: '5,7', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq26z_14511.pdf' },
                { model: 'AquaMaster 30Z', vykon: '14,9 kW', cop: '5,5', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq30z_14511.pdf' },
                { model: 'AquaMaster 37Z', vykon: '18,4 kW', cop: '5,4', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq37z_14511.pdf' },
                { model: 'AquaMaster 45Z', vykon: '22,5 kW', cop: '5,5', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq45z_14511.pdf' },
                { model: 'AquaMaster 60Z', vykon: '31,2 kW', cop: '5,4', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq60z_14511.pdf' },
                { model: 'AquaMaster 75Z', vykon: '37,7 kW', cop: '5,2', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq75z_14511.pdf' },
                { model: 'AquaMaster 90Z', vykon: '45,0 kW', cop: '5,4', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq90z_14511.pdf' },
                { model: 'AquaMaster 120.2Z', vykon: '64,6 kW', cop: '5,6', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq120_2z_14511.pdf' },
                { model: 'AquaMaster 150.2Z', vykon: '79,3 kW', cop: '5,6', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq150_2z_14511.pdf' },
                { model: 'AquaMaster 180.2Z', vykon: '90,9 kW', cop: '5,5', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq180_2z_14511.pdf' },
              ].map((p, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                  <td class="px-5 py-3 font-bold text-charcoal-900">{p.model}</td>
                  <td class="px-5 py-3 text-charcoal-700">{p.vykon}</td>
                  <td class="px-5 py-3 font-semibold text-navy-700">{p.cop}</td>
                  <td class="px-5 py-3">
                    <a href={p.pdf} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs font-semibold text-brand-500 hover:text-brand-600 whitespace-nowrap">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                      Technický list
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-charcoal-400 mt-2">* Podmínky W10W35</p>
      </div>

      <!-- 2. AquaMaster Inverter -->
      <div id="aquamaster-inverter" class="scroll-mt-24 mb-16">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-10 bg-navy-700 text-white rounded-full flex items-center justify-center font-bold text-lg flex-shrink-0">2</div>
          <div>
            <h2 class="text-xl font-extrabold text-charcoal-900">AquaMaster Inverter</h2>
            <p class="text-charcoal-500 text-sm">Inverterová technologie, 1–54 kW</p>
          </div>
        </div>

        <div class="mb-6">
          <div class="flex gap-6 mb-4">
            <div class="flex-1">
              <p class="text-charcoal-600 text-sm leading-relaxed">
                AquaMaster Inverter s plynulou regulací výkonu. Ocenění FOR ARCH Grand Prix 2008. Široký rozsah výkonů a rozsáhlá volitelná výbava umožňují navrhnout systém přesně podle požadavků a dosáhnout optimální provozní ekonomiky.
              </p>
            </div>
            <img src="/images/products/aquamaster-inverter.png" alt="AquaMaster Inverter" class="w-36 h-36 object-contain flex-shrink-0 hidden sm:block" />
          </div>
          <div class="space-y-2">
            {[
              'inverterová technologie — plynulá regulace výkonu',
              'ocenění FOR ARCH Grand Prix 2008',
              'rozsáhlá výbava a možnosti rozšíření',
            ].map(item => (
              <div class="flex gap-2 items-start">
                <div class="w-4 h-4 bg-brand-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-charcoal-600 text-sm">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="overflow-x-auto rounded-xl border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-navy-700 text-white">
              <tr>
                <th class="text-left px-5 py-3 font-semibold">Model</th>
                <th class="text-left px-5 py-3 font-semibold">Výkon</th>
                <th class="text-left px-5 py-3 font-semibold">COP</th>
                <th class="px-5 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {[
                { model: 'AquaMaster 17I', vykon: '1–5 kW', cop: '4,3', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/2013/10/aq17i_bldc_14511_ehpa.pdf' },
                { model: 'AquaMaster 22I', vykon: '3–9 kW', cop: '4,5', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq22i_bldc_14511_ehpa.pdf' },
                { model: 'AquaMaster 26I', vykon: '4–13 kW', cop: '4,5', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/2013/10/aq26i_bldc_14511_ehpa_062014.pdf' },
                { model: 'AquaMaster 30I', vykon: '5–14 kW', cop: '4,6', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq30i_bldc_14511_ehpa.pdf' },
                { model: 'AquaMaster 37I', vykon: '6–20 kW', cop: '4,7', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/2013/10/aq37i_bldc_14511_ehpa_062014.pdf' },
                { model: 'AquaMaster 45I', vykon: '9–28 kW', cop: '4,6', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq45i_bldc_14511_ehpa.pdf' },
                { model: 'AquaMaster 60I', vykon: '13–41 kW', cop: '4,7', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/2013/10/MTTC_aq60i_bldc_14511_ehpa_072015.pdf' },
                { model: 'AquaMaster 90I', vykon: '24–54 kW', cop: '4,6', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/2013/10/MTTC_aq90i_bldc_14511_ehpa_072015.pdf' },
              ].map((p, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                  <td class="px-5 py-3 font-bold text-charcoal-900">{p.model}</td>
                  <td class="px-5 py-3 text-charcoal-700">{p.vykon}</td>
                  <td class="px-5 py-3 font-semibold text-navy-700">{p.cop}</td>
                  <td class="px-5 py-3">
                    <a href={p.pdf} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs font-semibold text-brand-500 hover:text-brand-600 whitespace-nowrap">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                      Technický list
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-charcoal-400 mt-2">* Podmínky W10W35, COP při 60 Hz</p>
      </div>

      <!-- 3. AquaMaster Inverter Combi -->
      <div id="aquamaster-combi" class="scroll-mt-24 mb-8">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-10 h-10 bg-navy-700 text-white rounded-full flex items-center justify-center font-bold text-lg flex-shrink-0">3</div>
          <div>
            <h2 class="text-xl font-extrabold text-charcoal-900">AquaMaster Inverter Combi</h2>
            <p class="text-charcoal-500 text-sm">All-in-one s integrovaným bojlerem, 3–20 kW</p>
          </div>
        </div>

        <div class="mb-6">
          <div class="flex gap-6 mb-4">
            <div class="flex-1">
              <p class="text-charcoal-600 text-sm leading-relaxed">
                Konstrukce „all in one" s integrovaným nerezovým zásobníkem TUV, solárním výměníkem a inverterovým kompresorem. Moderní BLDC kompresor s variabilními oběhovými čerpadly a unikátním řídicím systémem. Volitelný modul pasivního chlazení umožňuje přímé využití chladicího efektu země bez spotřeby energie.
              </p>
            </div>
            <img src="/images/products/aquamaster-inv-combi.png" alt="AquaMaster Inverter Combi" class="w-36 h-36 object-contain flex-shrink-0 hidden sm:block" />
          </div>
          <div class="space-y-2">
            {[
              'all-in-one — integrovaný nerezový bojler a solární výměník',
              'minimální nároky na instalaci a zapojení',
              'volitelné pasivní chlazení bez spotřeby energie',
            ].map(item => (
              <div class="flex gap-2 items-start">
                <div class="w-4 h-4 bg-brand-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-charcoal-600 text-sm">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="overflow-x-auto rounded-xl border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-navy-700 text-white">
              <tr>
                <th class="text-left px-5 py-3 font-semibold">Model</th>
                <th class="text-left px-5 py-3 font-semibold">Výkon</th>
                <th class="text-left px-5 py-3 font-semibold">COP</th>
                <th class="px-5 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {[
                { model: 'AquaMaster 22IC', vykon: '3–9 kW', cop: '4,5', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq22ic_bldc_14511.pdf' },
                { model: 'AquaMaster 26IC', vykon: '4–13 kW', cop: '4,5', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/2015/11/aq26ic_bldc_14511_ehpa_062014.pdf' },
                { model: 'AquaMaster 30IC', vykon: '5–14 kW', cop: '4,6', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/MTTC_aq30ic_bldc_14511.pdf' },
                { model: 'AquaMaster 37IC', vykon: '6–20 kW', cop: '4,7', pdf: 'https://www.uspornevytapeni.cz/wp-content/uploads/2015/11/aq37ic_bldc_14511_ehpa_062014.pdf' },
              ].map((p, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                  <td class="px-5 py-3 font-bold text-charcoal-900">{p.model}</td>
                  <td class="px-5 py-3 text-charcoal-700">{p.vykon}</td>
                  <td class="px-5 py-3 font-semibold text-navy-700">{p.cop}</td>
                  <td class="px-5 py-3">
                    <a href={p.pdf} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs font-semibold text-brand-500 hover:text-brand-600 whitespace-nowrap">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                      Technický list
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-charcoal-400 mt-2">* Podmínky W10W35</p>
      </div>

      <div class="mt-8">
        <a href="/tepelna-cerpadla/voda-voda" class="text-sm font-semibold text-brand-500 hover:text-brand-600 flex items-center gap-1">
          Více o tepelných čerpadlech voda–voda
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-3">Nevíte, který model vybrat?</h2>
      <p class="text-charcoal-500 mb-8">Pomůžeme vám vybrat správný výkon i typ — zdarma.</p>
      <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">Odeslat poptávku</a>
    </div>
  </section>
</Layout>
