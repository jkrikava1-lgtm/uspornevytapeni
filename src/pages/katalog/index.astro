---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Katalog tepelných čerpadel" description="Katalog tepelných čerpadel Master Therm — vzduch-voda, země-voda, voda-voda. Česká výroba, mezinárodní ocenění.">
  <PageHero
    title="Katalog tepelných čerpadel"
    subtitle="Tepelná čerpadla Master Therm — česká výroba, mezinárodní ocenění."
    breadcrumb={[{ label: 'Katalog', href: '/katalog' }]}
  />

  <section class="pt-10 pb-16 lg:pt-12 lg:pb-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <a href="/katalog/vzduch-voda" class="group bg-white rounded-xl border border-gray-200 hover:border-brand-300 hover:shadow-lg transition-all p-8 text-center">
          <img src="/images/products/boxair-inverter.png" alt="BoxAir Inverter" class="w-28 h-28 object-contain mx-auto mb-4" />
          <h2 class="text-lg font-bold text-charcoal-900 mb-2 group-hover:text-brand-500 transition-colors">Vzduch – voda</h2>
          <p class="text-sm text-charcoal-500 mb-4">Nejoblíbenější řešení pro rodinné domy. Rychlá instalace, nízké pořizovací náklady.</p>
          <span class="text-sm font-semibold text-brand-500 group-hover:text-brand-600">Zobrazit modely →</span>
        </a>

        <a href="/katalog/zeme-voda" class="group bg-white rounded-xl border border-gray-200 hover:border-brand-300 hover:shadow-lg transition-all p-8 text-center">
          <img src="/images/products/aquamaster-inverter.png" alt="AquaMaster Inverter" class="w-28 h-28 object-contain mx-auto mb-4" />
          <h2 class="text-lg font-bold text-charcoal-900 mb-2 group-hover:text-brand-500 transition-colors">Země – voda</h2>
          <p class="text-sm text-charcoal-500 mb-4">Nejvyšší účinnost díky stabilní teplotě zemského povrchu. Plošný kolektor nebo vrt.</p>
          <span class="text-sm font-semibold text-brand-500 group-hover:text-brand-600">Zobrazit modely →</span>
        </a>

        <a href="/katalog/voda-voda" class="group bg-white rounded-xl border border-gray-200 hover:border-brand-300 hover:shadow-lg transition-all p-8 text-center">
          <img src="/images/products/aquamaster-2z.png" alt="AquaMaster" class="w-28 h-28 object-contain mx-auto mb-4" />
          <h2 class="text-lg font-bold text-charcoal-900 mb-2 group-hover:text-brand-500 transition-colors">Voda – voda</h2>
          <p class="text-sm text-charcoal-500 mb-4">Špičková účinnost využívající podzemní vodu. Ideální tam, kde je dostatek spodní vody.</p>
          <span class="text-sm font-semibold text-brand-500 group-hover:text-brand-600">Zobrazit modely →</span>
        </a>

      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-3">Nevíte, který model vybrat?</h2>
      <p class="text-charcoal-500 mb-8">Pomůžeme vám vybrat správný výkon i typ — zdarma.</p>
      <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">Odeslat poptávku</a>
    </div>
  </section>
</Layout>
