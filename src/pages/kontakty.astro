---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import site from '../data/site.json';
import data from '../data/kontakty.json';
---

<Layout title="Kontakt" description="Kontaktujte Úsporné vytápění s.r.o. Telefon, e-mail, adresa. Jsme v Jičíně a pracujeme po celé ČR.">
  <PageHero
    title={data.hero_title}
    subtitle={data.hero_subtitle}
    breadcrumb={[{ label: 'Kontakt', href: '/kontakty' }]}
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <div class="space-y-6">
          <div class="bg-gray-50 rounded-xl p-8 border border-gray-200">
            <h2 class="text-xl font-bold text-charcoal-900 mb-6">{site.name}</h2>
            <div class="space-y-5">
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-navy-700 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-charcoal-400 font-semibold uppercase tracking-wider mb-1">Telefon</div>
                  <a href={site.phone_href} class="text-lg font-bold text-charcoal-900 hover:text-brand-500 transition-colors">{site.phone}</a>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-navy-700 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-charcoal-400 font-semibold uppercase tracking-wider mb-1">E-mail</div>
                  <a href={`mailto:${site.email}`} class="text-lg font-bold text-charcoal-900 hover:text-brand-500 transition-colors">{site.email}</a>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-navy-700 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-charcoal-400 font-semibold uppercase tracking-wider mb-1">Adresa</div>
                  <div class="font-bold text-charcoal-900">{site.address_line1}<br>{site.address_line2}</div>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-8 border border-gray-200">
            <h3 class="font-bold text-charcoal-900 mb-3">{data.billing_headline}</h3>
            <div class="text-sm text-charcoal-600 space-y-1">
              <p><span class="font-semibold">{data.billing_name_label}</span> {data.billing_name}</p>
              <p><span class="font-semibold">{data.billing_address_label}</span> {data.billing_address}</p>
            </div>
          </div>
        </div>

        <div class="bg-gray-100 rounded-xl overflow-hidden h-96 lg:h-auto">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2546.7!2d15.3635!3d50.4368!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sDělnická+395%2C+Jičín!5e0!3m2!1scs!2scz!4v1234567890"
            width="100%"
            height="100%"
            style="border:0;min-height:400px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa — Úsporné vytápění s.r.o., Jičín"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>
