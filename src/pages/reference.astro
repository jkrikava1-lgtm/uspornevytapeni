---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import ref from '../data/reference.json';
---

<Layout title="Reference" description="Realizované instalace tepelných čerpadel po celé ČR. Rodinné domy, bytové domy, komerční objekty.">
  <PageHero
    title={ref.hero_title}
    subtitle={ref.hero_subtitle}
    breadcrumb={[{ label: 'Reference', href: '/reference' }]}
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-14">
        {[
          { num: ref.stat1_num, label: ref.stat1_label },
          { num: ref.stat2_num, label: ref.stat2_label },
          { num: ref.stat3_num, label: ref.stat3_label },
          { num: ref.stat4_num, label: ref.stat4_label },
        ].map(item => (
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-200 text-center">
            <div class="text-3xl font-extrabold text-navy-700">{item.num}</div>
            <div class="text-xs text-charcoal-500 mt-1">{item.label}</div>
          </div>
        ))}
      </div>

      <!-- Reference grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {ref.references.map(item => (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
            <div class="bg-gray-100 h-44 flex items-center justify-center text-charcoal-300">
              <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-brand-500 uppercase tracking-wider">{item.lokalita}</span>
                <span class="text-xs text-charcoal-400">{item.rok}</span>
              </div>
              <h3 class="font-bold text-charcoal-900 mb-1">{item.typ}</h3>
              <div class="text-xs text-navy-700 font-semibold mb-3">{item.system}</div>
              <p class="text-sm text-charcoal-500 leading-relaxed">{item.popis}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-3">{ref.cta_headline}</h2>
      <p class="text-charcoal-500 mb-8">{ref.cta_text}</p>
      <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">
        {ref.cta_button}
      </a>
    </div>
  </section>
</Layout>
