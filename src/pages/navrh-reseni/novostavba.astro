---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Úsporné vytápění novostavby" description="Navrhujeme optimální systém vytápění pro novostavby. Tepelné čerpadlo, podlahové vytápění, chlazení — vše v jednom projektu na míru.">
  <PageHero
    title="Vytápění novostavby"
    subtitle="Novostavba je ideální příležitost navrhnout vytápění správně od začátku. Ušetříte desítky tisíc korun ročně — a nebudete muset nic přestavovat."
    breadcrumb={[{ label: 'Návrh řešení', href: '/navrh-reseni/novostavba' }, { label: 'Novostavba', href: '/navrh-reseni/novostavba' }]}
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <div class="text-brand-500 text-sm font-semibold uppercase tracking-wider mb-3">Proč řešit vytápění hned</div>
          <h2 class="text-3xl font-extrabold text-charcoal-900 mb-6">Správný základ = dlouhodobá úspora</h2>
          <div class="space-y-4 text-charcoal-600 leading-relaxed">
            <p>V novostavbě máte jedinečnou příležitost — od podlahy a rozvodů až po zdroj tepla — navrhnout vše jako celek. Tepelné čerpadlo + podlahové vytápění je dnes nejúspornější kombinace pro moderní domy.</p>
            <p>Navrhujeme systémy, které splňují požadavky na nízkoenergetické a pasivní domy. Zároveň pomůžeme s dokumentací pro stavební povolení i dotace.</p>
          </div>

          <div class="mt-8 space-y-4">
            {[
              { title: 'Kompletní projekt', desc: 'Tepelné čerpadlo, podlahové vytápění, TUV, chlazení — vše v jednom návrhu.' },
              { title: 'Splnění norem', desc: 'Projekt splňuje požadavky PENB třídy A a podmínky pro dotace.' },
              { title: 'Koordinace se stavbou', desc: 'Spolupracujeme s vaším architektem a stavební firmou.' },
              { title: 'Fotovoltaika v plánu?', desc: 'Navrhujeme systémy připravené na spolupráci s FV panely.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-8 h-8 bg-brand-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-charcoal-900 text-sm">{item.title}</div>
                  <div class="text-sm text-charcoal-500">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-gray-50 rounded-xl p-7 border border-gray-200">
            <h3 class="font-bold text-charcoal-900 mb-5">Doporučené řešení pro novostavbu</h3>
            <div class="space-y-4">
              {[
                { cislo: '1', nazev: 'Tepelné čerpadlo vzduch-voda', popis: 'Primární zdroj tepla a chladu. Zajistí vytápění, chlazení i ohřev TUV.' },
                { cislo: '2', nazev: 'Podlahové vytápění', popis: 'Nejkomfortnější a nejúspornější distribuce tepla v nízkoenergetickém domě.' },
                { cislo: '3', nazev: 'Zásobník TUV', popis: '200–300 litrů — dostatek teplé vody pro celou rodinu.' },
                { cislo: '4', nazev: 'Smart ovládání', popis: 'Regulace podle plánu, počasí, přítomnosti — automaticky nebo přes telefon.' },
              ].map(item => (
                <div class="flex gap-4">
                  <div class="w-7 h-7 bg-navy-700 rounded-md flex items-center justify-center flex-shrink-0 text-white font-bold text-xs">{item.cislo}</div>
                  <div>
                    <div class="font-semibold text-charcoal-900 text-sm">{item.nazev}</div>
                    <div class="text-xs text-charcoal-500 mt-0.5">{item.popis}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-navy-700 rounded-xl p-6 text-white">
            <div class="text-brand-400 text-xs font-semibold uppercase tracking-wider mb-2">Tip na dotaci</div>
            <p class="text-sm text-navy-200 leading-relaxed">Pro novostavby je dostupná dotace až <strong class="text-white">150 000 Kč</strong> z programu Nová zelená úsporám Light. Pomůžeme s žádostí.</p>
            <a href="/dotace" class="inline-flex items-center gap-1 text-sm font-semibold text-brand-400 hover:text-brand-300 mt-3">
              Zjistit více o dotacích
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-3">Stavíte? Poradíme vám zdarma.</h2>
      <p class="text-charcoal-500 mb-8">Čím dřív se ozvete, tím lépe — vytápění je lepší navrhnout před hrubou stavbou.</p>
      <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">Odeslat poptávku</a>
    </div>
  </section>
</Layout>
