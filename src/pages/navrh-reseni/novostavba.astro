---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import data from '../../data/novostavba.json';
---

<Layout title="Úsporné vytápění novostavby" description="Navrhujeme optimální systém vytápění pro novostavby. Tepelné čerpadlo, podlahové vytápění, chlazení — vše v jednom projektu na míru.">
  <PageHero
    title={data.hero_title}
    subtitle={data.hero_subtitle}
    breadcrumb={[{ label: 'Návrh řešení', href: '/navrh-reseni/novostavba' }, { label: 'Novostavba', href: '/navrh-reseni/novostavba' }]}
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <div class="text-brand-500 text-sm font-semibold uppercase tracking-wider mb-3">{data.why_label}</div>
          <h2 class="text-3xl font-extrabold text-charcoal-900 mb-6">{data.why_headline}</h2>
          <div class="space-y-4 text-charcoal-600 leading-relaxed">
            <p>{data.why_text1}</p>
            <p>{data.why_text2}</p>
          </div>

          <div class="mt-8 space-y-4">
            {[
              { title: data.feat1_title, desc: data.feat1_desc },
              { title: data.feat2_title, desc: data.feat2_desc },
              { title: data.feat3_title, desc: data.feat3_desc },
              { title: data.feat4_title, desc: data.feat4_desc },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-8 h-8 bg-brand-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-charcoal-900 text-sm">{item.title}</div>
                  <div class="text-sm text-charcoal-500">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-gray-50 rounded-xl p-7 border border-gray-200">
            <h3 class="font-bold text-charcoal-900 mb-5">{data.recommended_headline}</h3>
            <div class="space-y-4">
              {[
                { cislo: data.rec1_cislo, nazev: data.rec1_nazev, popis: data.rec1_popis },
                { cislo: data.rec2_cislo, nazev: data.rec2_nazev, popis: data.rec2_popis },
                { cislo: data.rec3_cislo, nazev: data.rec3_nazev, popis: data.rec3_popis },
                { cislo: data.rec4_cislo, nazev: data.rec4_nazev, popis: data.rec4_popis },
              ].map(item => (
                <div class="flex gap-4">
                  <div class="w-7 h-7 bg-navy-700 rounded-md flex items-center justify-center flex-shrink-0 text-white font-bold text-xs">{item.cislo}</div>
                  <div>
                    <div class="font-semibold text-charcoal-900 text-sm">{item.nazev}</div>
                    <div class="text-xs text-charcoal-500 mt-0.5">{item.popis}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-navy-700 rounded-xl p-6 text-white">
            <div class="text-brand-400 text-xs font-semibold uppercase tracking-wider mb-2">{data.tip_label}</div>
            <p class="text-sm text-navy-200 leading-relaxed">{data.tip_text}</p>
            <a href="/dotace" class="inline-flex items-center gap-1 text-sm font-semibold text-brand-400 hover:text-brand-300 mt-3">
              {data.tip_link}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-3">{data.cta_headline}</h2>
      <p class="text-charcoal-500 mb-8">{data.cta_text}</p>
      <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">{data.cta_button}</a>
    </div>
  </section>
</Layout>
