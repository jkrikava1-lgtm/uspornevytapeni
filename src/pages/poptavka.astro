---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Poptávka" description="Poptejte tepelné čerpadlo nebo úsporné vytápění. Bezplatná konzultace a návrh řešení na míru.">
  <PageHero
    title="Nezávazná poptávka"
    subtitle="Vyplňte formulář a my se vám ozveme do 24 hodin. Konzultace i návrh řešení jsou zcela zdarma."
    breadcrumb={[{ label: 'Poptávka', href: '/poptavka' }]}
  />

  <section class="pt-10 pb-16 lg:pt-12 lg:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Formulář -->
        <div class="lg:col-span-2">
          <form class="space-y-6" name="poptavka" method="POST" data-netlify="true">
            <input type="hidden" name="form-name" value="poptavka" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold text-charcoal-800 mb-2">Jméno a příjmení *</label>
                <input type="text" name="jmeno" required class="w-full px-4 py-3 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors" placeholder="Jan Novák" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-charcoal-800 mb-2">Telefon *</label>
                <input type="tel" name="telefon" required class="w-full px-4 py-3 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors" placeholder="+420 777 123 456" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-charcoal-800 mb-2">E-mail *</label>
              <input type="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors" placeholder="jan@example.cz" />
            </div>

            <div>
              <label class="block text-sm font-semibold text-charcoal-800 mb-2">Typ objektu</label>
              <select name="objekt" class="w-full px-4 py-3 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors text-charcoal-700">
                <option value="">Vyberte typ objektu</option>
                <option>Rodinný dům — novostavba</option>
                <option>Rodinný dům — rekonstrukce</option>
                <option>Bytový dům</option>
                <option>Komerční objekt</option>
                <option>Jiné</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-semibold text-charcoal-800 mb-2">Čím vytápíte nyní?</label>
              <select name="vytapeni" class="w-full px-4 py-3 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors text-charcoal-700">
                <option value="">Vyberte stávající zdroj</option>
                <option>Plynový kotel</option>
                <option>Elektrický kotel</option>
                <option>Kotel na tuhá paliva</option>
                <option>Tepelné čerpadlo (výměna)</option>
                <option>Novostavba — zatím nic</option>
                <option>Jiné</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-semibold text-charcoal-800 mb-2">Zpráva</label>
              <textarea name="zprava" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors resize-none" placeholder="Popište svou situaci, plochu domu, lokalitu nebo jakékoliv další informace..."></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input type="checkbox" name="souhlas" id="souhlas" required class="mt-1 w-4 h-4 accent-brand-500" />
              <label for="souhlas" class="text-xs text-charcoal-500 leading-relaxed">
                Souhlasím se zpracováním osobních údajů za účelem vyřízení mé poptávky. Údaje nebudou předány třetím stranám.
              </label>
            </div>

            <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors text-base">
              Odeslat poptávku
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </button>
          </form>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
            <h3 class="font-bold text-charcoal-900 mb-4">Kontakt</h3>
            <div class="space-y-3 text-sm text-charcoal-600">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-navy-700 rounded-md flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-charcoal-400">Telefon</div>
                  <a href="tel:+420777724573" class="font-semibold text-charcoal-900 hover:text-brand-500 transition-colors">+420 777 724 573</a>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-navy-700 rounded-md flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-charcoal-400">E-mail</div>
                  <a href="mailto:info@uspornevytapeni.cz" class="font-semibold text-charcoal-900 hover:text-brand-500 transition-colors">info@uspornevytapeni.cz</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-navy-700 rounded-md flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-charcoal-400">Adresa</div>
                  <div class="font-semibold text-charcoal-900">Dělnická 395<br>506 01 Jičín</div>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-navy-700 rounded-xl p-6 text-white">
            <div class="text-brand-400 text-xs font-semibold uppercase tracking-wider mb-3">Proč nás kontaktovat</div>
            <ul class="space-y-3 text-sm text-navy-200">
              {['Konzultace zdarma, bez závazků', 'Odpovíme do 24 hodin', 'Návrh řešení na míru', 'Pomůžeme s dotací'].map(item => (
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
