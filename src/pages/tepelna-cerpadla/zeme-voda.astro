---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import data from '../../data/zeme-voda.json';
---

<Layout title="Tepelná čerpadla země-voda" description="Tepelná čerpadla země-voda Master Therm. Nejvyšší účinnost díky stabilní teplotě zemského povrchu. Vrty nebo plošné kolektory.">
  <PageHero
    title={data.hero_title}
    subtitle={data.hero_subtitle}
    breadcrumb={[{ label: 'Tepelná čerpadla', href: '/tepelna-cerpadla/zeme-voda' }, { label: 'Země – voda', href: '/tepelna-cerpadla/zeme-voda' }]}
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <div class="text-brand-500 text-sm font-semibold uppercase tracking-wider mb-3">{data.how_label}</div>
          <h2 class="text-3xl font-extrabold text-charcoal-900 mb-6">{data.how_headline}</h2>
          <div class="space-y-4 text-charcoal-600 leading-relaxed">
            <p>{data.how_text1}</p>
            <p>{data.how_text2}</p>
          </div>

          <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-gray-50 rounded-xl p-5 border border-gray-200">
              <h4 class="font-bold text-charcoal-900 mb-2 text-sm">{data.option1_title}</h4>
              <p class="text-xs text-charcoal-500 leading-relaxed">{data.option1_desc}</p>
            </div>
            <div class="bg-gray-50 rounded-xl p-5 border border-gray-200">
              <h4 class="font-bold text-charcoal-900 mb-2 text-sm">{data.option2_title}</h4>
              <p class="text-xs text-charcoal-500 leading-relaxed">{data.option2_desc}</p>
            </div>
          </div>

          <div class="mt-6 space-y-3">
            {[
              { title: data.feat1_title, desc: data.feat1_desc },
              { title: data.feat2_title, desc: data.feat2_desc },
              { title: data.feat3_title, desc: data.feat3_desc },
            ].map(item => (
              <div class="flex gap-3">
                <div class="w-6 h-6 bg-brand-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <span class="font-semibold text-charcoal-900 text-sm">{item.title}</span>
                  <span class="text-sm text-charcoal-500"> — {item.desc}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-navy-700 rounded-2xl p-8 text-white">
            <div class="text-brand-400 text-sm font-semibold uppercase tracking-wider mb-4">{data.params_label}</div>
            <div class="space-y-3">
              {[
                { label: data.param1_label, value: data.param1_value },
                { label: data.param2_label, value: data.param2_value },
                { label: data.param3_label, value: data.param3_value },
                { label: data.param4_label, value: data.param4_value },
                { label: data.param5_label, value: data.param5_value },
                { label: data.param6_label, value: data.param6_value },
              ].map(item => (
                <div class="flex justify-between py-2 border-b border-navy-600 last:border-0">
                  <span class="text-sm text-navy-300">{item.label}</span>
                  <span class="text-sm font-semibold">{item.value}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
            <h3 class="font-bold text-charcoal-900 mb-3">{data.price_headline}</h3>
            <div class="text-2xl font-extrabold text-navy-700 mb-1">{data.price_value}</div>
            <p class="text-xs text-charcoal-500 mb-4">{data.price_note}</p>
            <a href="/dotace" class="text-sm font-semibold text-brand-500 hover:text-brand-600 flex items-center gap-1">
              {data.price_dotace_link}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-3">{data.cta_headline}</h2>
      <p class="text-charcoal-500 mb-8">{data.cta_text}</p>
      <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">{data.cta_button}</a>
    </div>
  </section>
</Layout>
