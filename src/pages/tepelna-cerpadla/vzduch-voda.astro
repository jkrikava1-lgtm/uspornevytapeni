---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Tepelná čerpadla vzduch-voda" description="Tepelná čerpadla vzduch-voda Master Therm. Nejrozšířenější typ — snadná instalace, výborná účinnost, vhodné pro 95 % domácností.">
  <PageHero
    title="Tepelná čerpadla vzduch – voda"
    subtitle="Nejoblíbenější řešení pro rodinné domy. Rychlá instalace, nízké pořizovací náklady, spolehlivý provoz i při teplotách pod −20 °C."
    breadcrumb={[{ label: 'Tepelná čerpadla', href: '/tepelna-cerpadla/vzduch-voda' }, { label: 'Vzduch – voda', href: '/tepelna-cerpadla/vzduch-voda' }]}
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <div class="text-brand-500 text-sm font-semibold uppercase tracking-wider mb-3">Jak to funguje</div>
          <h2 class="text-3xl font-extrabold text-charcoal-900 mb-6">Teplo ze vzduchu — jednoduše a efektivně</h2>
          <div class="space-y-4 text-charcoal-600 leading-relaxed">
            <p>Tepelné čerpadlo vzduch-voda odebírá energii z venkovního vzduchu a přeměňuje ji na teplo pro vytápění a ohřev teplé vody. Z každé 1 kWh elektrické energie vytvoří 3–5 kWh tepla.</p>
            <p>Venkovní jednotka se umístí na fasádu nebo pozemek, vnitřní jednotka do technické místnosti. Zásah do stavby je minimální — instalace trvá typicky 1–2 dny.</p>
          </div>

          <div class="mt-8 space-y-4">
            {[
              { title: 'Funguje až do −22 °C', desc: 'Moderní inverterová technologie udržuje výkon i při extrémních mrazech.' },
              { title: 'Topí i chladí', desc: 'V létě jednoduše obrátí chod a funguje jako klimatizace.' },
              { title: 'Online ovládání', desc: 'Mobilní aplikace, programování, dohled na spotřebu — vše z telefonu.' },
              { title: 'Tichý provoz', desc: 'Hlučnost pod 45 dB — tiché jako běžná konverzace.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-8 h-8 bg-brand-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-charcoal-900 text-sm">{item.title}</div>
                  <div class="text-sm text-charcoal-500">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-navy-700 rounded-2xl p-8 text-white">
            <div class="text-brand-400 text-sm font-semibold uppercase tracking-wider mb-4">Technické parametry</div>
            <div class="space-y-3">
              {[
                { label: 'Výkonový rozsah', value: '6 – 60 kW' },
                { label: 'Topný faktor COP', value: '3,5 – 5,2' },
                { label: 'Min. venkovní teplota', value: '−22 °C' },
                { label: 'Max. teplota výstupu', value: '65 °C' },
                { label: 'Hlučnost', value: '< 45 dB(A)' },
                { label: 'Životnost', value: '20–25 let' },
              ].map(item => (
                <div class="flex justify-between py-2 border-b border-navy-600 last:border-0">
                  <span class="text-sm text-navy-300">{item.label}</span>
                  <span class="text-sm font-semibold">{item.value}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
            <h3 class="font-bold text-charcoal-900 mb-3">Orientační cena</h3>
            <div class="text-2xl font-extrabold text-navy-700 mb-1">200 000 – 400 000 Kč</div>
            <p class="text-xs text-charcoal-500 mb-4">Včetně instalace, zásobníku TUV a uvedení do provozu</p>
            <a href="/dotace" class="text-sm font-semibold text-brand-500 hover:text-brand-600 flex items-center gap-1">
              + dotace až 200 000 Kč
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-3">Hodí se vzduch-voda pro váš dům?</h2>
      <p class="text-charcoal-500 mb-8">Pošlete poptávku a my vám připravíme konkrétní návrh s výpočtem úspory.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">Chci nabídku</a>
        <a href="/katalog" class="inline-flex items-center justify-center px-6 py-3.5 border-2 border-gray-200 hover:border-gray-400 text-charcoal-700 font-semibold rounded-md transition-colors">Prohlédnout katalog</a>
      </div>
    </div>
  </section>
</Layout>
