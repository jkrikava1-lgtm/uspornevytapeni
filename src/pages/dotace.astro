---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import data from '../data/dotace.json';
---

<Layout title="Dotace na tepelné čerpadlo" description="Jak získat dotaci až 200 000 Kč na tepelné čerpadlo. Nová zelená úsporám, podmínky, postup žádosti. Pomůžeme vám od začátku do konce.">
  <PageHero
    title={data.hero_title}
    subtitle={data.hero_subtitle}
    breadcrumb={[{ label: 'Dotace', href: '/dotace' }]}
  />

  <section class="pt-10 pb-16 lg:pt-12 lg:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Přehled dotací -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        {[
          { program: data.program1_name, castka: data.program1_castka, desc: data.program1_desc },
          { program: data.program2_name, castka: data.program2_castka, desc: data.program2_desc },
          { program: data.program3_name, castka: data.program3_castka, desc: data.program3_desc },
        ].map(item => (
          <div class="bg-white rounded-xl p-7 border-2 border-gray-200 hover:border-brand-300 transition-colors">
            <div class="text-xs text-brand-500 font-semibold uppercase tracking-wider mb-2">{item.program}</div>
            <div class="text-3xl font-extrabold text-navy-700 mb-3">{item.castka}</div>
            <p class="text-sm text-charcoal-500 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-2xl font-extrabold text-charcoal-900 mb-6">{data.conditions_headline}</h2>
          <div class="space-y-4">
            {[
              { title: data.condition1_title, desc: data.condition1_desc },
              { title: data.condition2_title, desc: data.condition2_desc },
              { title: data.condition3_title, desc: data.condition3_desc },
              { title: data.condition4_title, desc: data.condition4_desc },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-6 h-6 bg-brand-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-charcoal-900 text-sm">{item.title}</div>
                  <div class="text-sm text-charcoal-500 mt-0.5">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-extrabold text-charcoal-900 mb-6">{data.process_headline}</h2>
          <div class="space-y-5">
            {[
              { krok: data.step1_krok, title: data.step1_title, desc: data.step1_desc },
              { krok: data.step2_krok, title: data.step2_title, desc: data.step2_desc },
              { krok: data.step3_krok, title: data.step3_title, desc: data.step3_desc },
              { krok: data.step4_krok, title: data.step4_title, desc: data.step4_desc },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-8 h-8 bg-navy-700 rounded-lg flex items-center justify-center flex-shrink-0 text-white font-bold text-sm">{item.krok}</div>
                <div>
                  <div class="font-semibold text-charcoal-900 text-sm">{item.title}</div>
                  <div class="text-sm text-charcoal-500 mt-0.5">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-500 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="text-2xl font-extrabold text-white">{data.cta_headline}</h3>
        <p class="text-white/80 text-sm mt-1">{data.cta_text}</p>
      </div>
      <a href="/poptavka" class="flex-shrink-0 inline-flex items-center px-6 py-3 bg-white text-brand-600 font-semibold rounded-md hover:bg-brand-50 transition-colors text-sm">
        {data.cta_button}
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>
