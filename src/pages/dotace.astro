---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import data from '../data/dotace.json';
---

<Layout title="Dotace na tepelné čerpadlo" description="Dotace na tepelná čerpadla — Nová zelená úsporám 2026. Informace o programu, podmínky, jak se připravit. Pomůžeme vám celý proces zvládnout.">
  <PageHero
    title={data.hero_title}
    subtitle={data.hero_subtitle}
    breadcrumb={[{ label: 'Dotace', href: '/dotace' }]}
  />

  <section class="pt-10 pb-16 lg:pt-12 lg:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Upozornění -->
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-12">
        <div class="flex gap-3">
          <svg class="w-6 h-6 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-sm text-amber-800 leading-relaxed">{data.intro}</p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-16">

        <!-- Co zatím víme -->
        <div>
          <h2 class="text-2xl font-extrabold text-charcoal-900 mb-6">{data.what_we_know_headline}</h2>
          <div class="space-y-3">
            {data.what_we_know.map(item => (
              <div class="flex gap-3 items-start">
                <div class="w-5 h-5 bg-brand-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-sm text-charcoal-600 leading-relaxed">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Jak se připravit -->
        <div>
          <h2 class="text-2xl font-extrabold text-charcoal-900 mb-6">{data.how_to_prepare_headline}</h2>
          <div class="space-y-5">
            {data.steps.map(step => (
              <div class="flex gap-4">
                <div class="w-8 h-8 bg-navy-700 rounded-lg flex items-center justify-center flex-shrink-0 text-white font-bold text-sm">{step.krok}</div>
                <div>
                  <div class="font-semibold text-charcoal-900 text-sm">{step.title}</div>
                  <div class="text-sm text-charcoal-500 mt-0.5">{step.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Předchozí programy -->
      <div>
        <h2 class="text-2xl font-extrabold text-charcoal-900 mb-6">{data.previous_headline}</h2>
        <p class="text-sm text-charcoal-500 mb-6">Pro orientaci uvádíme přehled dotací z předchozích let. Nový program bude pravděpodobně podobný.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {data.previous_programs.map(item => (
            <div class="bg-gray-50 rounded-xl p-7 border border-gray-200">
              <div class="text-xs text-charcoal-400 font-semibold uppercase tracking-wider mb-2">{item.program}</div>
              <div class="text-3xl font-extrabold text-navy-700 mb-3">{item.castka}</div>
              <p class="text-sm text-charcoal-500 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-500 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="text-2xl font-extrabold text-white">{data.cta_headline}</h3>
        <p class="text-white/80 text-sm mt-1">{data.cta_text}</p>
      </div>
      <a href="/poptavka" class="flex-shrink-0 inline-flex items-center px-6 py-3 bg-white text-brand-600 font-semibold rounded-md hover:bg-brand-50 transition-colors text-sm">
        {data.cta_button}
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>
</Layout>
