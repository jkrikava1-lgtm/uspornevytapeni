---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import data from '../data/cena.json';
---

<Layout title="Cena tepelného čerpadla" description="Kolik stojí tepelné čerpadlo? Orientační ceny včetně instalace, faktory ovlivňující cenu a návratnost investice.">
  <PageHero
    title={data.hero_title}
    subtitle={data.hero_subtitle}
    breadcrumb={[{ label: 'Cena', href: '/cena' }]}
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Cenové tabulky -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        {[
          {
            typ: data.price1_typ,
            rozsah: data.price1_rozsah,
            poznamka: data.price1_poznamka,
            body: [data.price1_body1, data.price1_body2, data.price1_body3],
            highlight: true,
          },
          {
            typ: data.price2_typ,
            rozsah: data.price2_rozsah,
            poznamka: data.price2_poznamka,
            body: [data.price2_body1, data.price2_body2, data.price2_body3],
            highlight: false,
          },
          {
            typ: data.price3_typ,
            rozsah: data.price3_rozsah,
            poznamka: data.price3_poznamka,
            body: [data.price3_body1, data.price3_body2, data.price3_body3],
            highlight: false,
          },
        ].map(item => (
          <div class={`rounded-xl p-7 border-2 ${item.highlight ? 'border-brand-500 bg-brand-50' : 'border-gray-200 bg-white'}`}>
            {item.highlight && <div class="text-xs text-brand-500 font-semibold uppercase tracking-wider mb-3">Nejoblíbenější</div>}
            <h3 class="text-lg font-bold text-charcoal-900 mb-2">{item.typ}</h3>
            <div class="text-2xl font-extrabold text-navy-700 mb-1">{item.rozsah}</div>
            <div class="text-xs text-charcoal-400 mb-5">{item.poznamka}</div>
            <ul class="space-y-2">
              {item.body.map(b => (
                <li class="flex items-center gap-2 text-sm text-charcoal-600">
                  <svg class="w-4 h-4 text-brand-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  {b}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-2xl font-extrabold text-charcoal-900 mb-6">{data.factors_headline}</h2>
          <div class="space-y-4">
            {[
              { title: data.factor1_title, desc: data.factor1_desc },
              { title: data.factor2_title, desc: data.factor2_desc },
              { title: data.factor3_title, desc: data.factor3_desc },
              { title: data.factor4_title, desc: data.factor4_desc },
            ].map(item => (
              <div class="flex gap-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
                <div class="w-8 h-8 bg-navy-700 rounded-md flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-charcoal-900 text-sm">{item.title}</div>
                  <div class="text-sm text-charcoal-500 mt-0.5">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-navy-700 rounded-2xl p-8 text-white">
          <div class="text-brand-400 text-sm font-semibold uppercase tracking-wider mb-4">{data.roi_label}</div>
          <h3 class="text-xl font-extrabold mb-6">{data.roi_headline}</h3>
          <div class="space-y-5">
            <div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-navy-300">{data.roi_annual_savings_label}</span>
                <span class="font-bold">{data.roi_annual_savings}</span>
              </div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-navy-300">{data.roi_price_label}</span>
                <span class="font-bold">{data.roi_price}</span>
              </div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-navy-300">{data.roi_dotace_label}</span>
                <span class="font-bold text-brand-400">{data.roi_dotace}</span>
              </div>
              <div class="border-t border-navy-600 pt-3 mt-3">
                <div class="flex justify-between text-sm">
                  <span class="text-navy-300">{data.roi_net_label}</span>
                  <span class="font-bold text-white">{data.roi_net}</span>
                </div>
                <div class="flex justify-between text-sm mt-1">
                  <span class="text-navy-300">{data.roi_payback_label}</span>
                  <span class="font-extrabold text-brand-400 text-lg">{data.roi_payback}</span>
                </div>
              </div>
            </div>
          </div>
          <p class="text-xs text-navy-400 mt-6">{data.roi_footnote}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-3">{data.cta_headline}</h2>
      <p class="text-charcoal-500 mb-8">{data.cta_text}</p>
      <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">
        {data.cta_button}
      </a>
    </div>
  </section>
</Layout>
