---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Desuperheater — ohřev teplé vody" description="Desuperheater využívá odpadní teplo kompresoru k ohřevu teplé užitkové vody. Výsledek: TUV zdarma v létě a výrazná úspora celoročně.">
  <PageHero
    title="Desuperheater"
    subtitle="Využijte odpadní teplo kompresoru k ohřevu teplé vody. V letním provozu prakticky zadarmo — bez dodatečné spotřeby elektřiny."
    breadcrumb={[{ label: 'Chytré funkce', href: '/chytre-funkce/desuperheater' }, { label: 'Desuperheater', href: '/chytre-funkce/desuperheater' }]}
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <div class="text-brand-500 text-sm font-semibold uppercase tracking-wider mb-3">Jak to funguje</div>
          <h2 class="text-3xl font-extrabold text-charcoal-900 mb-6">Odpadní teplo kompresoru — zdarma na TUV</h2>
          <div class="space-y-4 text-charcoal-600 leading-relaxed">
            <p>Při provozu tepelného čerpadla vzniká v kompresoru teplo, které by jinak bylo odváděno ven jako odpad. Desuperheater toto teplo zachytí a přesměruje ho do zásobníku teplé užitkové vody (TUV).</p>
            <p>V letním období, kdy čerpadlo chladí nebo jen ohřívá vodu, pokryje desuperheater prakticky veškerou potřebu TUV bez jakékoliv přídavné spotřeby elektřiny.</p>
          </div>

          <div class="mt-8 space-y-4">
            {[
              { title: 'TUV v létě prakticky zdarma', desc: 'V letním provozu (chlazení) ohřívá desuperheater vodu jako vedlejší produkt — nulová přídavná spotřeba.' },
              { title: 'Úspora 15–25 % ročně', desc: 'Ohřev teplé vody tvoří velkou část spotřeby domácnosti — desuperheater ji výrazně sníží.' },
              { title: 'Bezúdržbový provoz', desc: 'Žádné pohyblivé části, žádná obsluha. Funguje automaticky jako součást systému TČ.' },
              { title: 'Kombinace se zásobníkem', desc: 'Funguje s běžným zásobníkem TUV — není potřeba speciální vybavení.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-8 h-8 bg-brand-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-charcoal-900 text-sm">{item.title}</div>
                  <div class="text-sm text-charcoal-500">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-navy-700 rounded-2xl p-8 text-white">
            <div class="text-brand-400 text-sm font-semibold uppercase tracking-wider mb-5">Roční přínos desuperheateru</div>
            <div class="space-y-4">
              <div>
                <div class="flex justify-between text-sm mb-2">
                  <span class="text-navy-300">Průměrná roční úspora</span>
                  <span class="font-bold">5 000–10 000 Kč</span>
                </div>
                <div class="flex justify-between text-sm mb-2">
                  <span class="text-navy-300">Letní měsíce (TUV zdarma)</span>
                  <span class="font-bold text-brand-400">~6 měsíců</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-navy-300">Příplatek za desuperheater</span>
                  <span class="font-bold">15 000–25 000 Kč</span>
                </div>
              </div>
              <div class="border-t border-navy-600 pt-4">
                <div class="flex justify-between text-sm">
                  <span class="text-navy-300">Návratnost</span>
                  <span class="font-extrabold text-brand-400 text-lg">2–4 roky</span>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
            <h3 class="font-bold text-charcoal-900 mb-2">Volitelné příslušenství</h3>
            <p class="text-sm text-charcoal-500 leading-relaxed">Desuperheater je volitelnou součástí tepelného čerpadla Master Therm. Doporučujeme ho u každé novostavby a rekonstrukce — návratnost je velmi rychlá.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-3">Zajímá vás desuperheater?</h2>
      <p class="text-charcoal-500 mb-8">Rádi ho zařadíme do návrhu — konzultace je zdarma.</p>
      <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">Odeslat poptávku</a>
    </div>
  </section>
</Layout>
