---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import data from '../../data/desuperheater.json';
---

<Layout title="Desuperheater — ohřev teplé vody" description="Desuperheater využívá odpadní teplo kompresoru k ohřevu teplé užitkové vody. Výsledek: TUV zdarma v létě a výrazná úspora celoročně.">
  <PageHero
    title={data.hero_title}
    subtitle={data.hero_subtitle}
    breadcrumb={[{ label: 'Chytré funkce', href: '/chytre-funkce/desuperheater' }, { label: 'Desuperheater', href: '/chytre-funkce/desuperheater' }]}
  />

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <div class="text-brand-500 text-sm font-semibold uppercase tracking-wider mb-3">{data.intro_label}</div>
          <h2 class="text-3xl font-extrabold text-charcoal-900 mb-6">{data.intro_headline}</h2>
          <div class="space-y-4 text-charcoal-600 leading-relaxed">
            <p>{data.intro_text1}</p>
            <p>{data.intro_text2}</p>
          </div>

          <div class="mt-8 space-y-4">
            {[
              { title: data.feat1_title, desc: data.feat1_desc },
              { title: data.feat2_title, desc: data.feat2_desc },
              { title: data.feat3_title, desc: data.feat3_desc },
              { title: data.feat4_title, desc: data.feat4_desc },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-8 h-8 bg-brand-50 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-charcoal-900 text-sm">{item.title}</div>
                  <div class="text-sm text-charcoal-500">{item.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-navy-700 rounded-2xl p-8 text-white">
            <div class="text-brand-400 text-sm font-semibold uppercase tracking-wider mb-5">{data.roi_label}</div>
            <div class="space-y-4">
              <div>
                <div class="flex justify-between text-sm mb-2">
                  <span class="text-navy-300">{data.roi_savings_label}</span>
                  <span class="font-bold">{data.roi_savings}</span>
                </div>
                <div class="flex justify-between text-sm mb-2">
                  <span class="text-navy-300">{data.roi_summer_label}</span>
                  <span class="font-bold text-brand-400">{data.roi_summer}</span>
                </div>
                <div class="flex justify-between text-sm">
                  <span class="text-navy-300">{data.roi_cost_label}</span>
                  <span class="font-bold">{data.roi_cost}</span>
                </div>
              </div>
              <div class="border-t border-navy-600 pt-4">
                <div class="flex justify-between text-sm">
                  <span class="text-navy-300">{data.roi_payback_label}</span>
                  <span class="font-extrabold text-brand-400 text-lg">{data.roi_payback}</span>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
            <h3 class="font-bold text-charcoal-900 mb-2">{data.box_headline}</h3>
            <p class="text-sm text-charcoal-500 leading-relaxed">{data.box_text}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-extrabold text-charcoal-900 mb-3">{data.cta_headline}</h2>
      <p class="text-charcoal-500 mb-8">{data.cta_text}</p>
      <a href="/poptavka" class="inline-flex items-center justify-center px-6 py-3.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold rounded-md transition-colors">{data.cta_button}</a>
    </div>
  </section>
</Layout>
