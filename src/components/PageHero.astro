---
interface Props {
  title: string;
  subtitle?: string;
  breadcrumb?: { label: string; href: string }[];
}
const { title, subtitle, breadcrumb } = Astro.props;
---

<section class="bg-navy-700 text-white pt-16 lg:pt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-7 lg:py-9">
    {breadcrumb && (
      <nav class="flex items-center gap-2 text-xs text-navy-300 mb-3">
        <a href="/" class="hover:text-white transition-colors">Úvod</a>
        {breadcrumb.map(item => (
          <>
            <svg class="w-3 h-3 text-navy-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <a href={item.href} class="hover:text-white transition-colors">{item.label}</a>
          </>
        ))}
      </nav>
    )}
    <div class="max-w-3xl">
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-white mb-2">{title}</h1>
      {subtitle && <p class="text-base text-navy-200 leading-relaxed">{subtitle}</p>}
    </div>
  </div>
</section>
